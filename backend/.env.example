# Django Settings
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# SMS Settings (SMSC.kz)
SMSC_LOGIN=
SMSC_PASSWORD=
SMSC_SENDER=AQLANT
SMSC_API_URL=https://smsc.kz/sys/send.php

# Email Settings
# Вариант 1: SendGrid (рекомендуется — стабильная доставка в Gmail, list.ru)
# Регистрация: sendgrid.com, бесплатно 100 писем/день. Создайте API Key и верифицируйте отправителя.
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=info@aqlant.com

# Вариант 2: Обычный SMTP (mail.aqlant.com)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.aqlant.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=info@aqlant.com
EMAIL_HOST_PASSWORD=Aqlant2026!
DEFAULT_FROM_EMAIL=info@aqlant.com

# Настройки письма при регистрации студента
FRONTEND_URL=https://aqlant.com
REGISTRATION_FROM_EMAIL=info@aqlant.com
REGISTRATION_PROGRAM_NAME=Обучение на платформе Aqlant
REGISTRATION_COORDINATOR_PHONE=
REGISTRATION_COORDINATOR_EMAIL=

# Celery Configuration (optional)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
